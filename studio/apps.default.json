{
  "groups": [
    { "id": "vetnow", "name": "VetNow Kärnten", "color": "#0f9b8e", "icon": "🐾", "description": "Notfall-Tierarzt-Finder — Web, iPhone & Extension" },
    { "id": "avocado", "name": "Avocado at Law", "color": "#58CC02", "icon": "🥑", "description": "Duolingo für Recht — Web & iPhone" },
    { "id": "andere", "name": "Weitere Projekte", "color": "#2e6f9e", "icon": "🗂️", "description": "Eigene Apps hinzufügen (auch aus fremden Git-Repos)" }
  ],
  "apps": [
    {
      "id": "avocado-web",
      "name": "Web-App",
      "group": "avocado",
      "color": "#58CC02",
      "icon": "🥑",
      "kind": "web",
      "webDir": "avocado/web",
      "distDir": "dist",
      "basePath": "/avocado/",
      "buildCmd": "mkdir -p dist && cp index.html styles.css *.jsx dist/"
    },
    {
      "id": "avocado-mobile",
      "name": "iPhone-App (Expo Go)",
      "group": "avocado",
      "color": "#2F7D4F",
      "icon": "📱",
      "kind": "expo",
      "expoDir": "avocado/mobile",
      "expoSdk": "54",
      "expoPort": 8083,
      "env": {}
    },
    {
      "id": "vetnow-web-clean",
      "name": "Web-App (sauber)",
      "group": "vetnow",
      "color": "#0f9b8e",
      "icon": "🐾",
      "kind": "web",
      "webDir": "web",
      "distDir": "dist",
      "basePath": "/vetnow/",
      "buildCmd": "npm ci && VITE_VN_CLEAN=true npm run build"
    },
    {
      "id": "vetnow-web-demo",
      "name": "Web-App (Demo + Bot)",
      "group": "vetnow",
      "color": "#19b3a4",
      "icon": "🧪",
      "kind": "web",
      "webDir": "web",
      "distDir": "dist-demo",
      "basePath": "/vetnow-demo/",
      "buildCmd": "npm ci && npx vite build --base=/vetnow-demo/ --outDir dist-demo"
    },
    {
      "id": "vetnow-mobile-clean",
      "name": "iPhone-App (sauber)",
      "group": "vetnow",
      "color": "#0c7d72",
      "icon": "📱",
      "kind": "expo",
      "expoDir": "mobile",
      "expoSdk": "54",
      "expoPort": 8081,
      "env": { "EXPO_PUBLIC_VN_CLEAN": "true" }
    },
    {
      "id": "vetnow-mobile-demo",
      "name": "iPhone-App (Demo + Bot)",
      "group": "vetnow",
      "color": "#2e6f9e",
      "icon": "🧫",
      "kind": "expo",
      "expoDir": "mobile",
      "expoSdk": "54",
      "expoPort": 8082,
      "env": {}
    },
    {
      "id": "vetnow-extension",
      "name": "Chrome-Extension",
      "group": "vetnow",
      "color": "#8a5d05",
      "icon": "🧩",
      "kind": "extension",
      "extensionDir": "extension"
    }
  ]
}
